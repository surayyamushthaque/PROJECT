<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>User Management - CHRONIC Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700;900&family=Barlow+Condensed:wght@700;900&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --sidebar-bg: #0b132b;
      --sidebar-width: 220px;
      --topbar-bg: #e8e8e8;
      --main-bg: #7a7a7a;
      --card-bg: #f0f0f0;
      --accent-blue: #1a9ef5;
      --font: 'Barlow', sans-serif;
      --font-display: 'Barlow Condensed', sans-serif;
    }

    body {
      font-family: var(--font);
      background: var(--main-bg);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* TOP BAR */
    .topbar {
      background: var(--topbar-bg);
      height: 44px;
      display: flex;
      align-items: center;
      padding: 0 20px;
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      border-bottom: 1px solid #ccc;
    }
    .topbar-brand {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: 1.2rem;
      letter-spacing: 2px;
      color: #1a1a1a;
    }
    .topbar-brand em {
      display: inline-block;
      width: 10px; height: 10px;
      background: transparent;
      border: 2px solid #1a1a1a;
      border-radius: 50%;
      font-style: normal;
      vertical-align: middle;
      position: relative; top: -1px;
    }

    /* LAYOUT */
    .layout {
      display: flex;
      flex: 1;
      margin-top: 44px;
    }

    /* SIDEBAR */
    .sidebar {
      width: var(--sidebar-width);
      background: var(--sidebar-bg);
      min-height: calc(100vh - 44px);
      position: fixed;
      top: 44px; left: 0; bottom: 0;
      display: flex;
      flex-direction: column;
      padding-top: 28px;
      z-index: 90;
    }
    .sidebar-brand {
      font-family: var(--font-display);
      font-weight: 900;
      font-size: 1.6rem;
      letter-spacing: 3px;
      color: #fff;
      padding: 0 24px 28px;
    }
    .sidebar-brand em {
      display: inline-block;
      width: 11px; height: 11px;
      background: transparent;
      border: 2.5px solid #fff;
      border-radius: 50%;
      font-style: normal;
      vertical-align: middle;
      position: relative; top: -2px;
    }
    .sidebar nav a {
      display: block;
      color: #cdd4e0;
      text-decoration: none;
      font-size: 0.95rem;
      font-weight: 600;
      padding: 12px 24px;
      letter-spacing: 0.5px;
      transition: color 0.2s, background 0.2s;
    }
    .sidebar nav a:hover,
    .sidebar nav a.active {
      color: #fff;
      background: rgba(255,255,255,0.07);
    }

    /* MAIN */
    .main-content {
      margin-left: var(--sidebar-width);
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: calc(100vh - 44px);
    }

    /* PAGE HEADER */
    .page-header {
      background: #f5f5f5;
      padding: 16px 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid #ddd;
    }
    .page-header h2 {
      font-family: var(--font-display);
      font-size: 1.35rem;
      font-weight: 700;
      letter-spacing: 0.5px;
      color: #1a1a1a;
    }
    .page-header span { font-size: 0.9rem; color: #555; }

    /* CONTENT */
    .content-area { padding: 24px; flex: 1; }

    .admin-card {
      background: var(--card-bg);
      border-radius: 10px;
      padding: 24px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .admin-card h3 {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1.2rem;
      letter-spacing: 0.5px;
      color: #1a1a1a;
      margin-bottom: 18px;
    }

    /* SEARCH */
    .search-row { display: flex; gap: 10px; margin-bottom: 20px; }
    .search-row input {
      flex: 1;
      padding: 9px 14px;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-family: var(--font);
      font-size: 0.9rem;
      background: #fff;
      color: #1a1a1a;
      outline: none;
      transition: border-color 0.2s;
    }
    .search-row input:focus { border-color: var(--accent-blue); }
    .btn-search {
      background: var(--accent-blue);
      color: #fff; border: none;
      border-radius: 6px;
      padding: 9px 20px;
      font-family: var(--font);
      font-weight: 600; font-size: 0.88rem;
      cursor: pointer; transition: opacity 0.2s;
    }
    .btn-search:hover { opacity: 0.88; }
    .btn-clear {
      background: #888;
      color: #fff; border: none;
      border-radius: 6px;
      padding: 9px 20px;
      font-family: var(--font);
      font-weight: 600; font-size: 0.88rem;
      cursor: pointer; transition: opacity 0.2s;
    }
    .btn-clear:hover { opacity: 0.85; }

    /* TABLE */
    .admin-table { width: 100%; border-collapse: collapse; font-size: 0.92rem; }
    .admin-table thead tr { background: #e2e2e2; }
    .admin-table th {
      padding: 11px 16px;
      text-align: left;
      font-weight: 700; font-size: 0.85rem;
      letter-spacing: 0.4px; color: #1a1a1a;
      border-bottom: 2px solid #ccc;
    }
    .admin-table td {
      padding: 11px 16px;
      border-bottom: 1px solid #ddd;
      color: #333; vertical-align: middle;
    }
    .admin-table tbody tr:last-child td { border-bottom: none; }
    .admin-table tbody tr:hover { background: rgba(0,0,0,0.03); }

    /* BADGES */
    .badge-active {
      background: #0db88a; color: #fff;
      padding: 3px 10px; border-radius: 20px;
      font-size: 0.78rem; font-weight: 700;
    }
    .badge-blocked {
      background: #e53935; color: #fff;
      padding: 3px 10px; border-radius: 20px;
      font-size: 0.78rem; font-weight: 700;
    }

    /* ACTION BUTTONS */
    .btn-block-user {
      border: none; padding: 6px 14px;
      border-radius: 5px; color: white;
      font-family: var(--font);
      font-weight: 600; font-size: 0.82rem;
      cursor: pointer; transition: opacity 0.2s;
    }
    .btn-block-user:hover { opacity: 0.85; }
    .btn-block-user.blocked { background-color: #e53935; }
    .btn-block-user.active  { background-color: #0db88a; }

    /* PAGINATION */
    .pagination-row { display: flex; gap: 6px; margin-top: 18px; flex-wrap: wrap; }
    .pagination-row a {
      padding: 6px 13px; text-decoration: none;
      border: 1px solid #ccc; border-radius: 5px;
      color: #1a1a1a; font-size: 0.88rem; font-weight: 600;
      transition: background 0.2s;
    }
    .pagination-row a:hover { background: #ddd; }
    .pagination-row a.active-page {
      background: var(--sidebar-bg);
      color: white; border-color: var(--sidebar-bg);
    }

    /* FOOTER */
    .admin-footer {
      background: #111;
      padding: 36px 48px 24px;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      gap: 40px;
      align-items: start;
    }
    .footer-brand {
      font-family: var(--font-display);
      font-weight: 900; font-size: 1.5rem;
      letter-spacing: 3px; color: #fff; margin-bottom: 8px;
    }
    .footer-brand em {
      display: inline-block;
      width: 10px; height: 10px;
      border: 2px solid #fff;
      border-radius: 50%;
      font-style: normal;
      vertical-align: middle;
      position: relative; top: -2px;
    }
    .footer-copy { font-size: 0.78rem; color: #666; margin-top: 4px; }
    .footer-links h6, .footer-menu h6 {
      font-family: var(--font-display);
      font-weight: 700; font-size: 0.78rem;
      letter-spacing: 2px; text-transform: uppercase;
      color: #888; margin-bottom: 12px;
    }
    .footer-links a, .footer-menu a {
      display: block; color: #bbb;
      text-decoration: none; font-size: 0.85rem;
      margin-bottom: 7px; transition: color 0.2s;
    }
    .footer-links a:hover, .footer-menu a:hover { color: #fff; }
    .footer-menu { text-align: right; }
  </style>
</head>

<body>

  <!-- TOP BAR -->
  <div class="topbar">
    <div class="topbar-brand">CHR<em></em>NIC</div>
  </div>

  <div class="layout">
     <button id="sortBtn">Sort by Name ↑</button>
       <table border="1" cellspacing="0" cellpadding="10">
  <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Phone</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody id="usersBody">
    <!-- Users will appear here -->
  </tbody>
</table>


    <!-- SIDEBAR -->
    <aside class="sidebar">
      <div class="sidebar-brand">CHR<em></em>NIC</div>
      <nav>
        <a href="/admin/dashboard">Dashboard</a>
        <a href="/admin/orders">Orders</a>
        <a href="/admin/products">Products</a>
        <a href="/admin/users" class="active">Users</a>
        <a href="/admin/logout">Logout</a>
      </nav>
    </aside>

    <!-- MAIN CONTENT -->
    <div class="main-content">

      <div class="page-header">
        <h2>User Management</h2>
        <span>Welcome Admin</span>
      </div>

      <div class="content-area">
        <div class="admin-card">

          <h3>User Management</h3>

          <!-- SEARCH -->
          <div class="search-row">
            <input
              type="text"
              id="searchInput"
              placeholder="Search user..."
              value=""
            >
            <button class="btn-search" onclick="searchUser()">Search</button>
            <button class="btn-clear" onclick="clearSearch()">Clear</button>
          </div>

          <!-- TABLE -->
          <table class="admin-table">
            <thead>
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(user => { %>
                <tr>
                  <td><%= user.name %></td>
                  <td><%= user.email %></td>
                  <td>
                    <% if(user.isBlocked){ %>
                      <span class="badge-blocked">Blocked</span>
                    <% } else { %>
                      <span class="badge-active">Active</span>
                    <% } %>
                  </td>
                  <td>
                    <button
                      class="btn-block-user <%= user.isBlocked ? 'active' : 'blocked' %>"
                      onclick="toggleBlock('<%= user._id %>')"
                    >
                      <%= user.isBlocked ? "Unblock" : "Block" %>
                    </button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>

          <!-- PAGINATION -->
          <div class="pagination-row">
            <% for(let i = 1; i <= totalPages; i++) { %>
              <a
                href="?page=<%= i %>&search=<%= search %>"
                class="<%= currentPage === i ? 'active-page' : '' %>"
              >
                <%= i %>
              </a>
            <% } %>
          </div>

        </div>
      </div>

    </div>
  </div>

  <!-- FOOTER -->
  <footer class="admin-footer">
    <div>
      <div class="footer-brand">CHR<em></em>NIC</div>
      <div class="footer-copy">© 2024 CHRONIC. All rights reserved.</div>
    </div>
    <div class="footer-links">
      <h6>Help</h6>
      <a href="#">Shipping</a>
      <a href="#">Contact Us</a>
      <a href="#">Return &amp; Exchange Policy</a>
    </div>
    <div class="footer-menu">
      <h6>Menu</h6>
      <a href="#">About Me</a>
      <a href="#">Privacy Policy</a>
      <a href="#">Terms of Service</a>
    </div>
  </footer>

  <!-- Axios -->
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
  <script>


    let sortOrder = "asc"; // default ascending

async function fetchUsers() {
  try {
    const res = await axios.get(`/admin/users?sortOrder=${sortOrder}`);
    if(res.data.success){
      renderUsers(res.data.users);
    }
  } catch (err) {
    console.error("Error fetching users:", err);
  }
}

function renderUsers(users) {
  const tbody = document.getElementById("usersBody");
  tbody.innerHTML = "";
  users.forEach(user => {
    const tr = document.createElement("tr");
    tr.innerHTML = `
      <td>${user.name}</td>
      <td>${user.email}</td>
      <td>${user.phone || ""}</td>
      <td>${user.isBlocked ? "Blocked" : "Active"}</td>
    `;
    tbody.appendChild(tr);
  });
}

// Toggle sort on button click
document.getElementById("sortBtn").addEventListener("click", () => {
  sortOrder = sortOrder === "asc" ? "desc" : "asc";
  document.getElementById("sortBtn").innerText = 
      `Sort by Name ${sortOrder === "asc" ? "↑" : "↓"}`;
  fetchUsers();
});

// Initial load
fetchUsers();

     
   
    function toggleBlock(id) {
      if (confirm("Are you sure you want to change user status?")) {
        axios.patch(`/admin/user/block/${id}`)
          .then(() => { location.reload(); })
          .catch(err => console.log(err));
      }
    }

    function searchUser() {
      const value = document.getElementById("searchInput").value;
      window.location.href = `/admin/users?search=${value}`;
    }

    function clearSearch() {
      window.location.href = "/admin/users";
    }
  </script>

</body>
</html>
