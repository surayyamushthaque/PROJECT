<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>User Management</title>

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700&family=DM+Sans&display=swap" rel="stylesheet">

<style>
body {
  font-family: 'DM Sans', sans-serif;
  background: #0c0f14;
  color: #e8edf5;
  padding: 30px;
}

/* SEARCH BAR */
.search-wrap {
  position: relative;
  width: 350px;
  margin-bottom: 20px;
}

.search-wrap input {
  width: 100%;
  padding: 10px 110px 10px 38px;
  background: #1a2030;
  border: 1px solid #232b3a;
  border-radius: 8px;
  color: white;
}

.icon-search {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  width: 16px;
}

.search-actions {
  position: absolute;
  right: 6px;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  gap: 6px;
}

#btnSearch {
  background: #4f8eff;
  color: white;
  border: none;
  padding: 6px 10px;
  border-radius: 6px;
  cursor: pointer;
}

#btnClear {
  background: transparent;
  border: 1px solid #232b3a;
  color: #aaa;
  padding: 6px 8px;
  border-radius: 6px;
  cursor: pointer;
}

/* TABLE */
table {
  width: 100%;
  border-collapse: collapse;
}

th, td {
  padding: 12px;
  border-bottom: 1px solid #232b3a;
}

th {
  text-align: left;
  color: #aaa;
}

button {
  padding: 6px 10px;
  cursor: pointer;
}
</style>
</head>

<body>

<!-- SEARCH -->
<form method="GET" action="/admin/users">
  <div class="search-wrap">

    <svg class="icon-search" viewBox="0 0 24 24" stroke="white">
      <circle cx="11" cy="11" r="8"/>
    </svg>

    <input 
      type="text"
      name="search"
      id="searchInput"
      value="<%= search %>"
      placeholder="Search users..."
    >

    <div class="search-actions">
      <button type="submit" id="btnSearch">Search</button>
      <button type="button" id="btnClear">✕</button>
    </div>

  </div>
</form>

<!-- TABLE -->
<table>
<thead>
<tr>
<th>Joined</th>
<th>User</th>
<th>Phone</th>
<th>Status</th>
<th>Action</th>
</tr>
</thead>

<tbody>
<% if (users.length > 0) { %>
  <% users.forEach(user => { %>
    <tr>

      <td>
        <%= user.createdAt ? new Date(user.createdAt).toLocaleDateString() : 'N/A' %>
      </td>

      <td>
        <strong><%= user.name %></strong><br>
        <small><%= user.email %></small>
      </td>

      <td><%= user.phone || 'N/A' %></td>

      <td>
        <% if (user.isBlocked) { %>
          <span style="color:red;">Blocked</span>
        <% } else { %>
          <span style="color:green;">Active</span>
        <% } %>
      </td>

      <td>
        <% if (user.isBlocked) { %>
          <form action="/admin/unblock-user/<%= user._id %>" method="POST">
            <button type="submit">Unblock</button>
          </form>
        <% } else { %>
          <form action="/admin/block-user/<%= user._id %>" method="POST">
            <button type="submit">Block</button>
          </form>
        <% } %>
      </td>

    </tr>
  <% }) %>
<% } else { %>
  <tr>
    <td colspan="5">No users found</td>
  </tr>
<% } %>
</tbody>

</table>

<!-- PAGINATION -->
<div style="margin-top:20px;">
  Showing 
  <b><%= (page - 1) * 10 + 1 %>–<%= Math.min(page * 10, total) %></b> 
  of <b><%= total %></b>
</div>

<!-- SCRIPT -->
<script>
 
const searchInput = document.getElementById("searchInput");
const btnClear = document.getElementById("btnClear");

let debounceTimer;

// CLEAR BUTTON
btnClear.addEventListener("click", () => {
  searchInput.value = "";
  window.location.href = "/admin/users";
});

// DEBOUNCE SEARCH
searchInput.addEventListener("input", function () {
  const query = this.value.trim();

  clearTimeout(debounceTimer);

  debounceTimer = setTimeout(() => {
    window.location.href = `/admin/users?search=${query}`;
  }, 500);
});
</script>

</body>
</html>