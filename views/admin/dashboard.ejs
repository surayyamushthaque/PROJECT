<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      display: flex;
      flex-direction: column;

      /* ✅ Same background as admin login */
      background: url('/images/login-bg.jpg') no-repeat center center/cover;
      position: relative;
    }

    /* Dark overlay — same as admin login */
    body::before {
      content: "";
      position: fixed;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.5);
      z-index: 0;
    }

    /* ===== HEADER ===== */
    .top-header {
      background: #e8e8e8;
      padding: 12px 28px;
      border-bottom: 2px solid #3a3aff;
      display: flex;
      align-items: center;
      position: relative;
      z-index: 100;
    }

    .brand {
      font-family: 'Arial Black', Arial, sans-serif;
      font-weight: 900;
      font-size: 15px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #1a1a1a;
      display: flex;
      align-items: center;
      gap: 1px;
      text-decoration: none;
    }

    .brand-dot {
      display: inline-block;
      width: 11px;
      height: 11px;
      border-radius: 50%;
      border: 2px solid #1a1a1a;
      margin: 0 2px;
      flex-shrink: 0;
    }

    /* ===== LAYOUT WRAPPER ===== */
    .layout-wrapper {
      flex: 1;
      display: flex;
      position: relative;
      z-index: 1;
    }

    /* ===== SIDEBAR ===== */
    .sidebar {
      width: 230px;
      min-height: 100%;
      background: rgba(11, 19, 43, 0.92);
      color: white;
      padding: 20px;
      flex-shrink: 0;
      backdrop-filter: blur(4px);
    }

    .sidebar h4 {
      margin-bottom: 30px;
      font-family: 'Arial Black', Arial, sans-serif;
      letter-spacing: 0.1em;
    }

    .sidebar a {
      display: block;
      color: white;
      margin: 10px 0;
      text-decoration: none;
    }

    .sidebar a:hover {
      color: #00d4ff;
    }

    /* ===== MAIN CONTENT ===== */
    .main {
      flex: 1;
      padding: 20px;
      overflow-y: auto;
    }

    /* Topbar */
    .topbar {
      background: rgba(255, 255, 255, 0.92);
      padding: 10px 20px;
      border-radius: 10px;
      margin-bottom: 20px;
      display: flex;
      justify-content: space-between;
      backdrop-filter: blur(4px);
    }

    /* Cards */
    .card-box {
      border-radius: 10px;
      padding: 20px;
      color: white;
    }

    .bg1 { background: #6c5ce7; }
    .bg2 { background: #00b894; }
    .bg3 { background: #0984e3; }

    /* Chart + Table boxes */
    .bg-white {
      background: rgba(255, 255, 255, 0.92) !important;
      backdrop-filter: blur(4px);
    }

    .table-box {
      background: rgba(255, 255, 255, 0.92);
      padding: 20px;
      border-radius: 10px;
      backdrop-filter: blur(4px);
    }

    /* ===== FOOTER ===== */
    .footer {
      background: #1a1a1a;
      padding: 36px 48px 24px;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 28px;
      position: relative;
      z-index: 1;
    }

    .footer-brand {
      color: #ffffff;
      font-family: 'Arial Black', Arial, sans-serif;
      font-size: 22px;
      font-weight: 900;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      display: flex;
      align-items: center;
      gap: 2px;
      margin-bottom: 8px;
    }

    .footer-brand-dot {
      display: inline-block;
      width: 11px;
      height: 11px;
      border-radius: 50%;
      border: 2px solid #ffffff;
      margin: 0 2px;
      flex-shrink: 0;
    }

    .footer-copy {
      color: #555555;
      font-size: 10px;
      margin-top: 6px;
    }

    .footer-col h4 {
      color: #888888;
      font-family: 'Arial Black', Arial, sans-serif;
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      margin-bottom: 12px;
      font-weight: 900;
    }

    .footer-col a {
      display: block;
      color: #cccccc;
      font-size: 12px;
      margin-bottom: 7px;
      text-decoration: none;
      transition: color 0.18s;
    }

    .footer-col a:hover {
      color: #ffffff;
    }

    @media (max-width: 768px) {
      .sidebar { width: 180px; }
      .footer {
        padding: 28px 20px;
        flex-direction: column;
        gap: 20px;
      }
    }
  </style>
</head>

<body>

  <!-- ===== HEADER ===== -->
  <header class="top-header">
    <div class="brand">CHR<span class="brand-dot"></span>NIC</div>
  </header>

  <!-- ===== LAYOUT WRAPPER ===== -->
  <div class="layout-wrapper">

    <!-- Sidebar -->
    <div class="sidebar">
      <h4>CHRONIC</h4>
      <a href="#">Dashboard</a>
      <a href="#">Orders</a>
      <a href="#">Products</a>
      <a href="/admin/users">Users</a>
      <a href="/admin/logout">Logout</a>
    </div>

    <!-- Main -->
    <div class="main">

      <!-- Topbar -->
      <div class="topbar">
        <h5>Admin Dashboard</h5>
        <span id="adminName">Welcome Admin</span>
      </div>

      <!-- Cards -->
      <div class="row mb-4">
        <div class="col-md-4">
          <div class="card-box bg1">
            <h6>Total Sales</h6>
            <h3 id="sales">₹0</h3>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card-box bg2">
            <h6>Total Orders</h6>
            <h3 id="orders">0</h3>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card-box bg3">
            <h6>Total Users</h6>
            <h3 id="users">0</h3>
          </div>
        </div>
      </div>

      <!-- Chart -->
      <div class="bg-white p-4 mb-4 rounded">
        <h5>Sales Analytics</h5>
        <canvas id="chart"></canvas>
      </div>

      <!-- Table -->
      <div class="table-box">
        <h5>Recent Orders</h5>
        <table class="table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Product</th>
              <th>Amount</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody id="tableData"></tbody>
        </table>
      </div>

    </div>
  </div>

  <!-- ===== FOOTER ===== -->
  <footer class="footer">
    <div>
      <div class="footer-brand">CHR<span class="footer-brand-dot"></span>NIC</div>
      <div class="footer-copy">© 2024 CHRONIC. All rights reserved.</div>
    </div>
    <div class="footer-col">
      <h4>Help</h4>
      <a href="#">Shipping</a>
      <a href="#">Contact Us</a>
      <a href="#">Return &amp; Exchange Policy</a>
      <a href="#">Exchange Request</a>
      <a href="#">Warranty</a>
    </div>
    <div class="footer-col">
      <h4>Menu</h4>
      <a href="#">About Me</a>
      <a href="#">Privacy Policy</a>
      <a href="#">Terms of Service</a>
    </div>
  </footer>

  <!-- Axios -->
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

  <script>
    async function loadDashboard() {
      try {
        const res = await axios.get("/admin/dashboard-data");
        const data = res.data;

        // Cards
        document.getElementById("sales").innerText = "₹" + data.totalSales;
        document.getElementById("orders").innerText = data.totalOrders;
        document.getElementById("users").innerText = data.totalUsers;

        // Table
        const table = document.getElementById("tableData");
        table.innerHTML = "";
        data.orders.forEach(o => {
          table.innerHTML += `
            <tr>
              <td>${o.date}</td>
              <td>${o.product}</td>
              <td>₹${o.amount}</td>
              <td>${o.status}</td>
            </tr>
          `;
        });

        // Chart
        new Chart(document.getElementById("chart"), {
          type: "bar",
          data: {
            labels: ["Jan", "Feb", "Mar"],
            datasets: [{
              label: "Sales",
              data: data.chartData
            }]
          }
        });

      } catch (err) {
        console.log(err);
      }
    }

    loadDashboard();
  </script>

</body>
</html>