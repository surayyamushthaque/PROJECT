<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Recover Your Account – CHRONIC</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Cormorant+Garamond:wght@300;400;500&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blush:    #c9a09a;
      --blush-lt: #d9b4ae;
      --blush-dk: #b08880;
      --ink:      #1a1410;
      --cream:    #f5ede8;
      --gold:     #b5924c;
      --white:    #ffffff;
      --err:      #8b3a3a;
    }

    /* ── Page ── */
    html, body { height: 100%; }
    body {
      font-family: 'Montserrat', sans-serif;
      background-color: var(--blush);
      color: var(--ink);
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    /* ── Nav ── */
    nav {
      background: var(--blush-lt);
      display: flex;
      align-items: center;
      padding: 0 2.5rem;
      height: 58px;
      border-bottom: 1px solid rgba(0,0,0,.08);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .nav-brand {
      font-family: 'Playfair Display', serif;
      font-size: 1.25rem;
      font-weight: 700;
      letter-spacing: .18em;
      color: var(--ink);
      text-decoration: none;
      margin-right: auto;
    }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a {
      font-size: .68rem;
      font-weight: 600;
      letter-spacing: .13em;
      text-transform: uppercase;
      color: var(--ink);
      text-decoration: none;
      opacity: .75;
      transition: opacity .2s;
    }
    .nav-links a:hover { opacity: 1; }

    /* ── Hero / Content ── */
    main {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 4rem 1.5rem;
    }

    .card {
      background: rgba(255,255,255,.18);
      backdrop-filter: blur(6px);
      border: 1px solid rgba(255,255,255,.35);
      border-radius: 2px;
      padding: 3.5rem 3rem;
      width: 100%;
      max-width: 480px;
      animation: fadeUp .55s cubic-bezier(.22,1,.36,1) both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(22px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .card-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.75rem;
      font-weight: 400;
      letter-spacing: .04em;
      text-align: center;
      margin-bottom: .6rem;
      color: var(--ink);
    }
    .card-subtitle {
      font-size: .72rem;
      font-weight: 400;
      letter-spacing: .08em;
      text-align: center;
      color: var(--ink);
      opacity: .6;
      margin-bottom: 2.4rem;
    }

    /* ── Form ── */
    .field {
      position: relative;
      margin-bottom: 1.2rem;
    }
    .field input {
      width: 100%;
      padding: .9rem 1.1rem;
      font-family: 'Montserrat', sans-serif;
      font-size: .82rem;
      letter-spacing: .05em;
      background: var(--white);
      border: 1px solid rgba(0,0,0,.15);
      border-radius: 2px;
      color: var(--ink);
      outline: none;
      transition: border-color .2s, box-shadow .2s;
    }
    .field input::placeholder { color: rgba(26,20,16,.4); }
    .field input:focus {
      border-color: var(--gold);
      box-shadow: 0 0 0 3px rgba(181,146,76,.15);
    }
    .field input.error { border-color: var(--err); }

    .err-msg {
      font-size: .68rem;
      color: var(--err);
      letter-spacing: .04em;
      margin-top: .3rem;
      display: none;
    }
    .err-msg.visible { display: block; }

    /* ── Button ── */
    .btn-verify {
      display: block;
      width: 100%;
      padding: .88rem;
      background: var(--ink);
      color: var(--white);
      font-family: 'Montserrat', sans-serif;
      font-size: .7rem;
      font-weight: 600;
      letter-spacing: .2em;
      text-transform: uppercase;
      border: none;
      border-radius: 2px;
      cursor: pointer;
      transition: background .2s, transform .1s;
      position: relative;
      overflow: hidden;
    }
    .btn-verify:hover { background: #2e2620; }
    .btn-verify:active { transform: scale(.985); }
    .btn-verify:disabled { opacity: .55; cursor: not-allowed; }

    .btn-verify .spinner {
      display: none;
      width: 14px; height: 14px;
      border: 2px solid rgba(255,255,255,.3);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin .7s linear infinite;
      margin: 0 auto;
    }
    .btn-verify.loading .label { display: none; }
    .btn-verify.loading .spinner { display: block; }

    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Success ── */
    .success-box {
      display: none;
      text-align: center;
      animation: fadeUp .4s ease both;
    }
    .success-box.visible { display: block; }
    .success-icon {
      width: 48px; height: 48px;
      border-radius: 50%;
      background: var(--gold);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1.2rem;
      font-size: 1.3rem;
    }
    .success-box p {
      font-size: .8rem;
      letter-spacing: .04em;
      opacity: .75;
      line-height: 1.7;
    }

    /* ── Footer ── */
    footer {
      background: #141210;
      color: rgba(255,255,255,.55);
      display: grid;
      grid-template-columns: 1fr 2fr 1fr;
      align-items: start;
      gap: 2rem;
      padding: 3rem 2.5rem 2rem;
    }
    .footer-brand {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      font-weight: 700;
      letter-spacing: .14em;
      color: var(--white);
    }
    .footer-col h4 {
      font-size: .62rem;
      font-weight: 600;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: rgba(255,255,255,.35);
      margin-bottom: 1rem;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: .5rem; }
    .footer-col ul a {
      font-size: .72rem;
      letter-spacing: .04em;
      color: rgba(255,255,255,.55);
      text-decoration: none;
      transition: color .2s;
    }
    .footer-col ul a:hover { color: var(--white); }
    .footer-copy {
      grid-column: 1 / -1;
      font-size: .62rem;
      letter-spacing: .08em;
      border-top: 1px solid rgba(255,255,255,.08);
      padding-top: 1.2rem;
      margin-top: .5rem;
    }

    @media (max-width: 640px) {
      footer { grid-template-columns: 1fr; }
      nav { padding: 0 1.2rem; }
      .card { padding: 2.5rem 1.5rem; }
    }
  </style>
</head>
<body>

<!-- Nav -->
<nav>
  <a class="nav-brand" href="/">CHRONIC</a>
  <ul class="nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/best-sellers">Best Sellers</a></li>
    <li><a href="/contact">Contact</a></li>
  </ul>
</nav>

<!-- Main -->
<main>
  <div class="card" id="formCard">
    <h1 class="card-title">Recover Your Account</h1>
    <p class="card-subtitle">Enter your email or phone number to receive a verification link</p>
     
    <!-- Form -->
    <div id="recoveryForm">
      <div class="field">
        <input
          type="text"
          id="identifier"
          name="identifier"
          placeholder="enter your email or phone"
          autocomplete="username"
        />
        <p class="err-msg" id="fieldError">Please enter a valid email or phone number.</p>
      </div>

      <button class="btn-verify" id="verifyBtn" type="button" onclick="handleVerify()">
        <span class="label">Verify</span>
        <span class="spinner"></span>
      </button>

      <p class="err-msg" id="apiError" style="margin-top:.8rem;text-align:center;"></p>
    </div>

    <!-- Success State -->
    <div class="success-box" id="successBox">
      <div class="success-icon">✓</div>
      <h2 style="font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:.6rem;">Check your inbox</h2>
      <p>We've sent a recovery link to <strong id="identifierDisplay"></strong>. Follow the instructions to reset your account.</p>
    </div>
  </div>
</main>

<!-- Footer -->
<footer>
  <div class="footer-brand">CHRONIC</div>

  <div style="display:flex;gap:4rem;">
    <div class="footer-col">
      <h4>Help</h4>
      <ul>
        <li><a href="/shipping">Shipping</a></li>
        <li><a href="/contact">Contact Us</a></li>
        <li><a href="/returns">Return &amp; Exchange Policy</a></li>
        <li><a href="/exchange">Exchange request</a></li>
        <li><a href="/warranty">Warranty</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>Menu</h4>
      <ul>
        <li><a href="/about">About me</a></li>
        <li><a href="/privacy">Privacy Policy</a></li>
        <li><a href="/terms">Terms of service</a></li>
      </ul>
    </div>
  </div>

  <div></div>
  <p class="footer-copy">© 2025 · CHRONIC WATCH</p>
</footer>

<script>
  async function handleVerify() {
    const input     = document.getElementById('identifier');
    const btn       = document.getElementById('verifyBtn');
    const fieldErr  = document.getElementById('fieldError');
    const apiErr    = document.getElementById('apiError');
    const val       = input.value.trim();

    // Reset errors
    fieldErr.classList.remove('visible');
    apiErr.classList.remove('visible');
    input.classList.remove('error');

    // Basic validation
    const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const phoneRe = /^\+?[\d\s\-().]{7,15}$/;
    if (!val || (!emailRe.test(val) && !phoneRe.test(val))) {
      input.classList.add('error');
      fieldErr.classList.add('visible');
      return;
    }

    // Loading state
    btn.classList.add('loading');
    btn.disabled = true;

    try {
      await axios.post('/user/forgot-password', { email:val });

      // Show success
      document.getElementById('identifierDisplay').textContent = val;
      document.getElementById('recoveryForm').style.display = 'none';
      document.getElementById('successBox').classList.add('visible');
    } catch (err) {
      const msg = err?.response?.data?.message || 'Something went wrong. Please try again.';
      apiErr.textContent = msg;
      apiErr.classList.add('visible');
    } finally {
      btn.classList.remove('loading');
      btn.disabled = false;
    }
  }

  // Allow Enter key
  document.getElementById('identifier').addEventListener('keydown', e => {
    if (e.key === 'Enter') handleVerify();
  });
</script>

</body>
</html>
