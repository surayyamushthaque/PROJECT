<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Address</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Barlow', sans-serif; background:#f5f3ee; margin:0; }
    nav { background:#111; color:#fff; padding:15px 40px; display:flex; justify-content:space-between; }
    nav a { color:#ccc; text-decoration:none; margin-left:20px; font-size:13px; }
    .container { max-width: 560px; margin: 60px auto; }
    .card { background:#fff; border:1px solid #ddd; }
    .card-header { padding: 15px 20px; border-bottom:1px solid #eee; display:flex; justify-content:space-between; align-items:center; }
    .card-body { padding: 22px; }
    .form-group { margin-bottom: 14px; }
    label { display:block; font-size:12px; color:gray; margin-bottom:6px; }
    input { width:100%; padding:10px; border:1px solid #ccc; font-size:14px; }
    .btn { padding:10px 18px; border:none; cursor:pointer; font-size:13px; }
    .btn-dark { background:#111; color:#fff; }
    .btn-outline { border:1px solid #ccc; background:transparent; }
  </style>
</head>
<body>
  <nav>
    <div>CHRONIC</div>
    <div>
      <a href="/profile">Profile</a>
      <a href="/user/addresses">Addresses</a>
    </div>
  </nav>

  <div class="container">
    <div class="card">
      <div class="card-header">
        <h3>Edit Address</h3>
        <a href="/user/addresses"><button class="btn btn-outline">← Back</button></a>
      </div>

      <div class="card-body">
        <% if (message) { %>
          <div style="margin-bottom:12px;font-size:13px;color:<%= message.type === 'success' ? 'green' : 'red' %>">
            <%= message.text %>
          </div>
        <% } %>

        <form action="/user/addresses/edit/<%= address._id %>" method="POST" onsubmit="return validateEditAddress()">
          <div class="form-group">
            <label>Full Name</label>
            <input type="text" name="name" value="<%= address.name %>" required>
          </div>
          <div class="form-group">
            <label>Phone</label>
            <input type="text" id="phone" name="phone" value="<%= address.phone %>" required>
          </div>
          <div class="form-group">
            <label>Street</label>
            <input type="text" name="street" value="<%= address.street %>" required>
          </div>
          <div class="form-group">
            <label>City</label>
            <input type="text" name="city" value="<%= address.city %>" required>
          </div>
          <div class="form-group">
            <label>State</label>
            <input type="text" name="state" value="<%= address.state %>" required>
          </div>
          <div class="form-group">
            <label>Pincode / ZIP</label>
            <input type="text" id="pincode" name="pincode" value="<%= address.pincode %>" required>
          </div>
          <div class="form-group">
            <label>Country</label>
            <input type="text" name="country" value="<%= address.country %>" required>
          </div>
          <div class="form-group">
            <label>Landmark (optional)</label>
            <input type="text" name="landmark" value="<%= address.landmark || '' %>">
          </div>

          <div id="err" style="display:none;margin-bottom:12px;font-size:13px;color:red;"></div>

          <button type="submit" class="btn btn-dark">Save</button>
          <a href="/user/addresses"><button type="button" class="btn btn-outline">Cancel</button></a>
        </form>
      </div>
    </div>
  </div>

  <script>
  function validateEditAddress() {
    const phone = (document.getElementById("phone").value || "").trim();
    const pin = (document.getElementById("pincode").value || "").trim();
    const err = document.getElementById("err");

    if (!/^\+?[0-9]{10,15}$/.test(phone)) {
      err.style.display = "block";
      err.textContent = "Phone number is invalid.";
      return false;
    }
    if (!/^[0-9]{4,10}$/.test(pin)) {
      err.style.display = "block";
      err.textContent = "Pincode / ZIP must be numeric.";
      return false;
    }
    err.style.display = "none";
    err.textContent = "";
    return true;
  }
  </script>
</body>
</html>

