<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Edit Profile</title>

<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">

<style>
body {
  font-family: 'Barlow', sans-serif;
  background: #f5f3ee;
  margin: 0;
}

/* NAV */
nav {
  background: #111;
  color: #fff;
  padding: 15px 40px;
  display: flex;
  justify-content: space-between;
}

nav a {
  color: #ccc;
  text-decoration: none;
  margin-left: 20px;
  font-size: 13px;
}

/* LAYOUT */
.container {
  max-width: 900px;
  margin: 40px auto;
}

/* CARD */
.card {
  background: #fff;
  border: 1px solid #ddd;
}

.card-header {
  padding: 15px 20px;
  border-bottom: 1px solid #eee;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-body {
  padding: 25px;
}

/* AVATAR */
.avatar-section {
  text-align: center;
  margin-bottom: 20px;
}

.avatar-section img {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid #b08d57;
}

.avatar-section input {
  margin-top: 10px;
}

/* FORM */
.form-group {
  margin-bottom: 15px;
}

label {
  display: block;
  font-size: 12px;
  color: gray;
  margin-bottom: 5px;
}

input {
  width: 100%;
  padding: 10px;
  border: 1px solid #ccc;
  font-size: 14px;
}

/* ROW */
.row {
  display: flex;
  gap: 15px;
}

.row .form-group {
  flex: 1;
}

/* BUTTONS */
.btn {
  padding: 10px 18px;
  border: none;
  cursor: pointer;
  font-size: 13px;
}

.btn-dark {
  background: #111;
  color: #fff;
}

.btn-outline {
  border: 1px solid #ccc;
  background: transparent;
}

/* EMAIL VERIFY */
.email-row {
  display: flex;
  gap: 10px;
}

.email-row input {
  flex: 1;
}

/* MESSAGES */
.msg-success { color: green; }
.msg-error { color: red; }
</style>
</head>

<body>

<!-- NAV -->
<nav>
  <div>CHRONIC</div>
  <div>
    <a href="/">Home</a>
    <a href="/user/profile">Account</a>
    <a href="/user/login">Logout</a>
  </div>
</nav>

<div class="container">

  <div class="card">

    <div class="card-header">
      <h3>Edit Profile</h3>
      <a href="/user/profile"><button class="btn btn-outline">← Back</button></a>
    </div>

    <div class="card-body">

      <form action="/user/profile/edit" method="POST" enctype="multipart/form-data">

        <!-- AVATAR -->
        <div class="avatar-section">
          <img id="preview" src="<%= user.profileImage || '/images/avatar.png' %>">
          <br>
         <input type="file" name="profileImage" accept="image/*" onchange="previewImage(event)">

        <!-- NAME -->
        <div class="row">
          <div class="form-group">
            <label>Name</label>
            <input type="text" name="name" value="<%= user.name %>" required>
          </div>

          <div class="form-group">
            <label>Phone</label>
            <input type="text" name="phone" value="<%= user.phone %>">
          </div>
        </div>

        <!-- EMAIL -->
        <div class="form-group">
          <label>Email</label>

          <div class="email-row">
            <input type="email" id="email" name="email" value="<%= user.email %>">
            <button type="button" class="btn btn-dark" onclick="sendOtp()">Verify</button>
          </div>

          <small style="color:gray;font-size:12px;">
            Changing email requires verification
          </small>
        </div>

        <!-- BUTTONS -->
        <div style="margin-top:20px;">
          <button type="submit" class="btn btn-dark">Save Changes</button>
          <a href="user/profile"><button type="button" class="btn btn-outline">Cancel</button></a>
        </div>

      </form>

      <hr style="margin:28px 0;border:none;border-top:1px solid #eee;">

     

<script>
// preview image
function previewImage(event) {
  const reader = new FileReader();
  reader.onload = function() {
    document.getElementById('preview').src = reader.result;
  }
  reader.readAsDataURL(event.target.files[0]);
}

// send OTP
function sendOtp() {
  const email = document.getElementById("email").value;
  fetch("/profile/send-otp", {
    method: "POST"
    ,headers: { "Content-Type": "application/json" }
    ,body: JSON.stringify({ newEmail: email })
  })
  .then(async (res) => {
    if (!res.ok) {
      const data = await res.json().catch(() => ({}));
      throw new Error(data.message || "Failed to send OTP");
    }
    return res.json().catch(() => ({}));
  })
  .then(() => {
    alert("OTP sent!");
    window.location.href = "/profile/verify-email";
  })
  .catch((err) => alert(err.message));
}

function validatePasswordChange() {
  const newPw = document.getElementById("newPassword").value;
  const confirmPw = document.getElementById("confirmPassword").value;
  const errorEl = document.getElementById("pwError");

  if (newPw.length < 8) {
    errorEl.style.display = "block";
    errorEl.textContent = "New password must be at least 8 characters.";
    return false;
  }

  if (newPw !== confirmPw) {
    errorEl.style.display = "block";
    errorEl.textContent = "New password and confirm password do not match.";
    return false;
  }

  errorEl.style.display = "none";
  errorEl.textContent = "";
  return true;
}
</script>

</body>
</html>