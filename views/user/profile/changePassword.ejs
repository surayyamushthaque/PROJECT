<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Change Password</title>

<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">

<style>
body {
  font-family: 'Barlow', sans-serif;
  background: #f5f3ee;
  margin: 0;
}

/* NAV */
nav {
  background: #111;
  color: #fff;
  padding: 15px 40px;
  display: flex;
  justify-content: space-between;
}

nav a {
  color: #ccc;
  text-decoration: none;
  margin-left: 20px;
  font-size: 13px;
}

/* CONTAINER */
.container {
  max-width: 500px;
  margin: 60px auto;
}

/* CARD */
.card {
  background: #fff;
  border: 1px solid #ddd;
}

.card-header {
  padding: 15px 20px;
  border-bottom: 1px solid #eee;
  display: flex;
  justify-content: space-between;
}

.card-body {
  padding: 25px;
}

/* FORM */
.form-group {
  margin-bottom: 18px;
}

label {
  font-size: 12px;
  color: gray;
  display: block;
  margin-bottom: 5px;
}

input {
  width: 100%;
  padding: 10px;
  border: 1px solid #ccc;
  font-size: 14px;
}

/* PASSWORD STRENGTH */
.strength-bar {
  height: 4px;
  background: #ddd;
  margin-top: 5px;
}

.strength-fill {
  height: 100%;
  width: 0%;
  background: red;
  transition: 0.3s;
}

.hint {
  font-size: 12px;
  color: gray;
  margin-top: 5px;
}

/* BUTTONS */
.btn {
  padding: 10px 18px;
  border: none;
  cursor: pointer;
  font-size: 13px;
}

.btn-dark {
  background: #111;
  color: #fff;
}

.btn-outline {
  border: 1px solid #ccc;
  background: transparent;
}

/* MESSAGE */
.message {
  margin-top: 10px;
  font-size: 13px;
}
</style>
</head>

<body>

<!-- NAV -->
<nav>
  <div>CHRONIC</div>
  <div>
    <a href="/">Home</a>
    <a href="/profile">Account</a>
    <a href="/logout">Logout</a>
  </div>
</nav>

<div class="container">

  <div class="card">

    <div class="card-header">
      <h3>Change Password</h3>
      <a href="/profile"><button class="btn btn-outline">← Back</button></a>
    </div>

    <div class="card-body">

      <form action="/user/profile/change-password" method="POST">

        <!-- CURRENT PASSWORD -->
        <div class="form-group">
          <label>Current Password</label>
          <input type="password" name="currentPassword" required>
        </div>

        <!-- NEW PASSWORD -->
        <div class="form-group">
          <label>New Password</label>
          <input type="password" name="newPassword" id="newPassword" oninput="checkStrength(this.value)" required>

          <div class="strength-bar">
            <div class="strength-fill" id="strengthFill"></div>
          </div>

          <div class="hint" id="strengthText">
            Min 8 characters, include number & symbol
          </div>
        </div>

        <!-- CONFIRM -->
        <div class="form-group">
          <label>Confirm Password</label>
          <input type="password" name="confirmPassword" id="confirmPassword" required>
        </div>

        <!-- BUTTONS -->
        <div style="margin-top:20px;">
          <button type="submit" class="btn btn-dark">Update Password</button>
          <a href="/profile"><button type="button" class="btn btn-outline">Cancel</button></a>
        </div>

        
         <% if (message) { %>
         <div class="message" style="color:<%= message.type === 'success' ? 'green' : 'red' %>">
           <%= message.text %>
         </div>
         <% } %>

      </form>

    </div>
  </div>

</div>

<script>
function checkStrength(password) {
  const fill = document.getElementById("strengthFill");
  const text = document.getElementById("strengthText");

  let strength = 0;

  if (password.length >= 8) strength++;
  if (/[0-9]/.test(password)) strength++;
  if (/[^A-Za-z0-9]/.test(password)) strength++;
  if (password.length >= 12) strength++;

  const colors = ["red", "orange", "blue", "green"];
  const labels = ["Weak", "Fair", "Good", "Strong"];

  fill.style.width = (strength * 25) + "%";
  fill.style.background = colors[strength - 1] || "#ddd";
  text.textContent = strength ? labels[strength - 1] : "Min 8 characters, include number & symbol";
}
</script>

</body>
</html>