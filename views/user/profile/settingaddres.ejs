<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>My Addresses</title>

<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">

<style>
body {
  font-family: 'Barlow', sans-serif;
  background: #f5f3ee;
  margin: 0;
}

/* NAV */
nav {
  background: #111;
  color: #fff;
  padding: 15px 40px;
  display: flex;
  justify-content: space-between;
}

nav a {
  color: #ccc;
  text-decoration: none;
  margin-left: 20px;
  font-size: 13px;
}

/* CONTAINER */
.container {
  max-width: 1000px;
  margin: 40px auto;
}

/* HEADER */
.header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20px;
}

/* GRID */
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(250px,1fr));
  gap: 20px;
}

/* CARD */
.card {
  background: #fff;
  border: 1px solid #ddd;
  padding: 15px;
  position: relative;
}

.card.default {
  border: 2px solid #b08d57;
}

.tag {
  font-size: 11px;
  color: #b08d57;
  margin-bottom: 5px;
}

.name {
  font-weight: 600;
}

.text {
  font-size: 13px;
  color: gray;
}

/* BUTTONS */
.btn {
  padding: 6px 12px;
  font-size: 12px;
  border: none;
  cursor: pointer;
}

.btn-dark { background: #111; color: #fff; }
.btn-outline { border: 1px solid #ccc; background: transparent; }
.btn-danger { border: 1px solid red; color: red; background: transparent; }

.actions {
  margin-top: 10px;
  display: flex;
  gap: 5px;
  flex-wrap: wrap;
}

/* ADD CARD */
.add-card {
  border: 2px dashed #ccc;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

/* MODAL */
.modal {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.5);
  display: none;
  align-items: center;
  justify-content: center;
}

.modal-content {
  background: #fff;
  padding: 20px;
  width: 400px;
}

/* FORM */
input {
  width: 100%;
  padding: 8px;
  margin-bottom: 10px;
}
</style>
</head>

<body>

<nav>
  <div>CHRONIC</div>
  <div>
    <a href="/profile">Profile</a>
    <a href="/user/profile/change-password">Password</a>
  </div>
</nav>

<div class="container">

  <div class="header">
    <h2>My Addresses</h2>
    <button class="btn btn-dark" onclick="openModal()">+ Add Address</button>
  </div>

  <% if (message) { %>
    <div style="margin:10px 0;font-size:13px;color:<%= message.type === 'success' ? 'green' : 'red' %>">
      <%= message.text %>
    </div>
  <% } %>

  <div class="grid">

    <% addresses.forEach(addr => { %>
      <div class="card">

        <div class="name"><%= addr.name %></div>

        <div class="text">
          <%= addr.street %><br>
          <%= addr.city %>, <%= addr.state %> - <%= addr.pincode %><br>
          <%= addr.country %><br>
          <% if (addr.landmark) { %>Landmark: <%= addr.landmark %><br><% } %>
          <%= addr.phone %>
        </div>

        <div class="actions">
          <a href="/user/addresses/edit/<%= addr._id %>">
            <button type="button" class="btn btn-outline">Edit</button>
          </a>

          <form action="/user/addresses/delete/<%= addr._id %>" method="POST" onsubmit="return confirm('Delete this address?')">
            <button class="btn btn-danger" type="submit">Delete</button>
          </form>
        </div>

      </div>
    <% }) %>

    <!-- ADD CARD -->
    <div class="card add-card" onclick="openModal()">
      + Add Address
    </div>

  </div>
</div>

<!-- MODAL -->
<div class="modal" id="modal">
  <div class="modal-content">

    <h3 id="modalTitle">Add Address</h3>

    <form id="addressForm" method="POST" action="/user/addresses/add" onsubmit="return validateAddressForm()">

      <input type="text" name="name" placeholder="Full Name" required>
      <input type="text" name="phone" placeholder="Phone" required>
      <input type="text" name="street" placeholder="Address Line (Street)" required>
      <input type="text" name="city" placeholder="City" required>
      <input type="text" name="state" placeholder="State" required>
      <input type="text" name="pincode" placeholder="Pincode" required>
      <input type="text" name="country" placeholder="Country" required>
      <input type="text" name="landmark" placeholder="Landmark (optional)">

      <div id="addrError" style="display:none;margin-top:8px;font-size:13px;color:red;"></div>

      <button class="btn btn-dark">Save</button>
      <button type="button" class="btn btn-outline" onclick="closeModal()">Cancel</button>

    </form>

  </div>
</div>

<script>
function openModal() {
  document.getElementById("modal").style.display = "flex";
  document.getElementById("addressForm").reset();
  document.getElementById("addrError").style.display = "none";
  document.getElementById("addrError").textContent = "";
}

function closeModal() {
  document.getElementById("modal").style.display = "none";
}

function validateAddressForm() {
  const form = document.getElementById("addressForm");
  const phone = (form.phone.value || "").trim();
  const pin = (form.pincode.value || "").trim();
  const err = document.getElementById("addrError");

  if (!/^\+?[0-9]{10,15}$/.test(phone)) {
    err.style.display = "block";
    err.textContent = "Phone number is invalid.";
    return false;
  }
  if (!/^[0-9]{4,10}$/.test(pin)) {
    err.style.display = "block";
    err.textContent = "Pincode must be numeric.";
    return false;
  }
  err.style.display = "none";
  err.textContent = "";
  return true;
}
</script>

</body>
</html>