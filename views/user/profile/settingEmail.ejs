<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Verify Email</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Barlow', sans-serif; background:#f5f3ee; margin:0; }
    nav { background:#111; color:#fff; padding:15px 40px; display:flex; justify-content:space-between; }
    nav a { color:#ccc; text-decoration:none; margin-left:20px; font-size:13px; }
    .container { max-width: 520px; margin: 60px auto; }
    .card { background:#fff; border:1px solid #ddd; }
    .card-header { padding: 15px 20px; border-bottom:1px solid #eee; display:flex; justify-content:space-between; align-items:center; }
    .card-body { padding: 22px; }
    label { display:block; font-size:12px; color:gray; margin-bottom:6px; }
    input { width:100%; padding:10px; border:1px solid #ccc; font-size:14px; }
    .btn { padding:10px 18px; border:none; cursor:pointer; font-size:13px; }
    .btn-dark { background:#111; color:#fff; }
    .btn-outline { border:1px solid #ccc; background:transparent; }
    .hint { color: gray; font-size: 12px; margin-top: 10px; }
    .error { background:#fff2f2; border:1px solid #ffd0d0; color:#8b0000; padding:10px; font-size:13px; margin-bottom:12px; }
  </style>
</head>
<body>
  <nav>
    <div>CHRONIC</div>
    <div>
      <a href="/">Home</a>
      <a href="/user/profile">Account</a>
      <a href="/user/logout">Logout</a>
    </div>
  </nav>

  <div class="container">
    <div class="card">
      <div class="card-header">
        <h3>Verify new email</h3>
        <a href="/profile/edit"><button class="btn btn-outline">← Back</button></a>
      </div>

      <div class="card-body">
        <% if (error) { %>
          <div class="error"><%= error %></div>
        <% } %>

        <form action="/profile/verify-otp" method="POST">
          <div style="margin-bottom:14px;">
            <label>New email</label>
            <input type="email" name="newEmail" value="<%= pendingEmail %>" readonly />
            <div class="hint">We sent a 6-digit OTP to this address.</div>
          </div>

          <div style="margin-bottom:16px;">
            <label>OTP</label>
            <input type="text" name="otp" inputmode="numeric" autocomplete="one-time-code" maxlength="6" required />
          </div>

          <button type="submit" class="btn btn-dark">Verify & Update</button>
          <a href="/profile/edit"><button type="button" class="btn btn-outline">Cancel</button></a>
        </form>
      </div>
    </div>
  </div>
</body>
</html>