<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>My Profile</title>

<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">

<style>
body {
  font-family: 'Barlow', sans-serif;
  background: #f5f3ee;
  margin: 0;
}

/* NAV */
nav {
  background: #111;
  color: #fff;
  padding: 15px 40px;
  display: flex;
  justify-content: space-between;
}

nav a {
  color: #ccc;
  text-decoration: none;
  margin-left: 20px;
  font-size: 13px;
}

/* LAYOUT */
.container {
  max-width: 1000px;
  margin: 40px auto;
  display: flex;
  gap: 30px;
}

/* SIDEBAR */
.sidebar {
  width: 220px;
  background: #fff;
  border: 1px solid #ddd;
}

.sidebar .user {
  text-align: center;
  padding: 20px;
  border-bottom: 1px solid #eee;
}

.sidebar img {
  width: 70px;
  height: 70px;
  border-radius: 50%;
}

.sidebar h4 {
  margin: 10px 0 5px;
}

.sidebar p {
  font-size: 12px;
  color: gray;
}

.sidebar a {
  display: block;
  padding: 10px 20px;
  text-decoration: none;
  color: #555;
  font-size: 13px;
}

.sidebar a:hover {
  background: #f0eee9;
}

/* MAIN */
.main {
  flex: 1;
}

.card {
  background: #fff;
  border: 1px solid #ddd;
  margin-bottom: 20px;
}

.card-header {
  padding: 15px;
  border-bottom: 1px solid #eee;
  display: flex;
  justify-content: space-between;
}

.card-body {
  padding: 20px;
}

/* PROFILE */
.profile-row {
  margin-bottom: 10px;
}

.label {
  font-size: 12px;
  color: gray;
}

.value {
  font-weight: 500;
}

/* ADDRESS */
.address-box {
  border: 1px solid #ddd;
  padding: 15px;
  margin-top: 10px;
  font-size: 14px;
}

/* BUTTON */
.btn {
  padding: 6px 14px;
  border: none;
  cursor: pointer;
  font-size: 12px;
}

.btn-dark {
  background: #111;
  color: #fff;
}

.btn-outline {
  border: 1px solid #ccc;
  background: transparent;
}
</style>
</head>

<body>

<!-- NAV -->
<nav>
  <div>CHRONIC</div>
  <div>
    <a href="/">Home</a>
    <a href="/profile">Account</a>
    <a href="/user/login">Logout</a>
  </div>
</nav>

<div class="container">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="user">
      <img src="<%= user?.profileImage || '/images/avatar.png' %>"">
      <h4><%= user.name %></h4>
      <p><%= user.email %></p>
    </div>

    <a href="/user/profile">Profile</a>
    <a href="/address">Address</a>
    <a href="/user/profile/change-password">Change Password</a>
  </div>

  <!-- MAIN -->
  <div class="main">

    <!-- PROFILE -->
    <div class="card">
      <div class="card-header">
        <h3>Profile Details</h3>
        <a href="/profile/edit"><button class="btn btn-outline">Edit</button></a>
      </div>

      <div class="card-body">
        <div class="profile-row">
          <div class="label">Name</div>
          <div class="value"><%= user.name %></div>
        </div>

        <div class="profile-row">
          <div class="label">Email</div>
          <div class="value"><%= user.email %></div>
        </div>

        <div class="profile-row">
          <div class="label">Phone</div>
          <div class="value"><%= user.phone || 'Not added' %></div>
        </div>
      </div>
    </div>

    <!-- ADDRESS -->
    

  </div>
</div>

</body>
</html>