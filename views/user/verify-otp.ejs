
<%- include("../partials/headers", { title: "Signup", user: user }) %>

<!DOCTYPE html>
<html lang="en">
<!-- <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify OTP - Chronic</title> -->
  
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
    body { background: #c88989; display: flex; flex-direction: column; min-height: 100vh; justify-content: center; align-items: center; }
    
    .otp-container {
      background: #c88989;
      padding: 30px 20px;
      border-radius: 10px;
      text-align: center;
      width: 100%;
      max-width: 400px;
    }

    .otp-container h2 { font-weight: 500; margin-bottom: 20px; }

    .otp-container input {
      width: 100%;
      padding: 12px;
      border-radius: 6px;
      border: 1px solid #333;
      margin-bottom: 10px;
    }

    .otp-container button {
      width: 100%;
      padding: 12px;
      background: #000;
      color: #fff;
      border: none;
      border-radius: 6px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 10px;
    }

    .otp-container button:hover { background: #333; }

    .resend {
      font-size: 12px;
      color: #fff;
      margin-top: 5px;
    }

    .resend a { color: #ff5a5a; text-decoration: none; margin-left: 5px; cursor: pointer; }

    /* Toast notification */
    .toast {
      position: fixed;
      top: 20px;
      right: 20px;
      background: #333;
      color: #fff;
      padding: 12px 20px;
      border-radius: 8px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.3);
      z-index: 9999;
      transform: translateX(120%);
      transition: transform 0.3s ease;
      display: flex;
      align-items: center;
      gap: 10px;
    }
     
    #timer {
  font-weight: bold;
  color: #020202;       /* Red color to highlight */
  margin-right: 10px;    /* Space between timer and text */
  font-size: 14px;       /* Slightly bigger */
}
.resend a {
  color: #fff;
  background: #ff5a5a;
  padding: 2px 8px;
  border-radius: 4px;
  text-decoration: none;
  margin-left: 5px;
  font-size: 14px;
}
.resend a:hover {
  background: #ff0000;
}
.resend span {
  color: #fff;
  font-size: 14px;
}

    



    .toast.show { transform: translateX(0); }
    .toast.error { border-left: 4px solid #ff4d4d; }
    .toast.success { border-left: 4px solid #4caf50; }

    /* Footer */
    footer {
      margin-top: auto;
      width: 100%;
      background: #111;
      color: #fff;
      padding: 20px 0;
      display: flex;
      justify-content: space-around;
      flex-wrap: wrap;
      font-size: 12px;
    }

    footer h3 { font-size: 14px; margin-bottom: 10px; }
    footer a { color: #fff; text-decoration: none; display: block; margin-bottom: 5px; }
    footer a:hover { text-decoration: underline; }
  </style>
</head>
<body>

  <div class="otp-container">
    <h2>Verify OTP</h2>
   <input id="otp" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="6">
    <div class="resend">
  <span id="timer">00:60</span>
  <button id="resendBtn">Resend OTP</button>
</div>
    <button id="confirmBtn">CONFIRM</button>
  </div>

  <!-- Toast Notification -->
  <div id="toast" class="toast"><span id="toast-msg">Notification</span></div>


  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
  <script>
const toast = document.getElementById("toast");
const toastMsg = document.getElementById("toast-msg");

function showToast(msg, type="error") {
  toastMsg.textContent = msg;
  toast.className = `toast show ${type}`;
  setTimeout(() => toast.className = "toast", 3000);
}

const confirmBtn = document.getElementById("confirmBtn");
const resendBtn = document.getElementById("resendBtn");
const timerDisplay = document.getElementById("timer");

let countdown;
let timeLeft = 60; // ✅ FIXED

// ✅ VERIFY OTP
confirmBtn.addEventListener("click", async () => {
  const otp = document.getElementById("otp").value.trim();
  const email = localStorage.getItem("email"); // ✅ USE EMAIL

  if (!email) {
    showToast("Session expired. Please signup again.", "error");
    return;
  }

  if (!/^\d{6}$/.test(otp)) {
    showToast("Enter a valid 6-digit OTP", "error");
    return;
  }

  try {
    const res = await axios.post("/user/verify-otp", { email, otp });

    showToast(res.data.message || "OTP Verified!", "success");

    localStorage.removeItem("email");

    setTimeout(() => {
      window.location.href = "/user/login";
    }, 1500);

  } catch (err) {
    showToast(err.response?.data?.error || "Invalid OTP", "error");
  }
});


// ⏳ TIMER FUNCTION
function startTimer() {
  timeLeft = 60;
  resendBtn.disabled = true;

  timerDisplay.textContent = `00:${timeLeft}`;

  countdown = setInterval(() => {
    timeLeft--;

    timerDisplay.textContent =
      `00:${timeLeft < 10 ? '0' + timeLeft : timeLeft}`;

    if (timeLeft <= 0) {
      clearInterval(countdown);
      resendBtn.disabled = false;
      timerDisplay.textContent = "Resend available";
    }
  }, 1000);
}

// 🚀 START TIMER ON LOAD
window.onload = () => {
  startTimer();
};


// 🔁 RESEND OTP
resendBtn.addEventListener("click", async () => {
  const email = localStorage.getItem("email");

  if (!email) {
    showToast("Session expired.", "error");
    return;
  }

  try {
    await axios.post("/user/resend-otp", { email });

    showToast("OTP resent successfully", "success");

    startTimer(); // restart timer

  } catch (err) {
    showToast(err.response?.data?.error || "Could not resend OTP", "error");
  }
});
</script>

</body>
</html>

