<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Verify OTP – CHRONIC</title>
  <link rel="stylesheet" href="/css/verify-otp.css" />
</head>
<style>
    /* ===== FONTS ===== */
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Montserrat:wght@300;400;500;600;700&display=swap');

/* ===== RESET & BASE ===== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --rose:        #C9938A;
  --rose-light:  #D4A49C;
  --rose-pale:   #E8C5BF;
  --dark:        #1a1a1a;
  --dark-soft:   #2c2c2c;
  --white:       #ffffff;
  --red-accent:  #c0392b;
  --font-serif:  'Cormorant Garamond', serif;
  --font-sans:   'Montserrat', sans-serif;
}

html, body {
  height: 100%;
  font-family: var(--font-sans);
  background: var(--rose);
  color: var(--dark);
}

/* ===== NAVBAR ===== */
.navbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 48px;
  background: var(--white);
  border-bottom: 1px solid rgba(0,0,0,0.08);
  position: sticky;
  top: 0;
  z-index: 100;
}

.brand {
  font-family: var(--font-serif);
  font-size: 1.7rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-decoration: none;
  color: var(--dark);
  display: flex;
  align-items: center;
  gap: 0;
}

.brand-icon {
  color: var(--red-accent);
  font-size: 1.1em;
  line-height: 1;
  vertical-align: middle;
  display: inline-block;
  margin: 0 1px;
  font-style: normal;
}

.nav-links {
  list-style: none;
  display: flex;
  gap: 36px;
}

.nav-links a {
  text-decoration: none;
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--dark);
  transition: color 0.2s;
}

.nav-links a:hover { color: var(--red-accent); }

/* ===== OTP SECTION ===== */
.otp-section {
  min-height: calc(100vh - 64px - 220px);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--rose);
  padding: 60px 20px;
}

.otp-card {
  width: 100%;
  max-width: 480px;
  text-align: center;
}

.otp-title {
  font-family: var(--font-serif);
  font-size: 2rem;
  font-weight: 500;
  letter-spacing: 0.04em;
  color: var(--dark);
  margin-bottom: 32px;
}

/* ===== ALERT ===== */
.alert {
  padding: 11px 18px;
  border-radius: 4px;
  font-size: 0.8rem;
  font-weight: 500;
  letter-spacing: 0.04em;
  margin-bottom: 18px;
  text-align: left;
}

.alert-error   { background: #fdecea; color: #c0392b; border: 1px solid #f5c6c6; }
.alert-success { background: #eafaf1; color: #1e8449; border: 1px solid #a9dfbf; }

/* ===== FORM GROUP ===== */
.otp-form-group {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.otp-input {
  width: 100%;
  padding: 13px 18px;
  border: 1.5px solid rgba(0,0,0,0.18);
  border-radius: 4px;
  font-family: var(--font-sans);
  font-size: 0.88rem;
  letter-spacing: 0.06em;
  background: var(--white);
  color: var(--dark);
  outline: none;
  transition: border-color 0.22s, box-shadow 0.22s;
}

.otp-input::placeholder { color: #aaa; }

.otp-input:focus {
  border-color: var(--dark);
  box-shadow: 0 0 0 3px rgba(26,26,26,0.08);
}

.otp-input.error { border-color: var(--red-accent); }

/* ===== RESEND ROW ===== */
.resend-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8px;
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  color: var(--dark);
  text-transform: uppercase;
}

.resend-btn {
  background: none;
  border: none;
  cursor: pointer;
  font-family: var(--font-sans);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--red-accent);
  padding: 0;
  transition: opacity 0.2s;
}

.resend-btn:hover  { opacity: 0.7; }
.resend-btn:disabled { opacity: 0.4; cursor: not-allowed; }

/* ===== CONFIRM BUTTON ===== */
.confirm-btn {
  width: 100%;
  padding: 14px;
  background: var(--dark);
  color: var(--white);
  border: none;
  cursor: pointer;
  font-family: var(--font-sans);
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  border-radius: 3px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  transition: background 0.22s, transform 0.12s;
}

.confirm-btn:hover  { background: #333; }
.confirm-btn:active { transform: scale(0.99); }
.confirm-btn:disabled { background: #888; cursor: not-allowed; }

/* ===== SPINNER ===== */
.spinner {
  width: 16px; height: 16px;
  border: 2.5px solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ===== FOOTER ===== */
.footer {
  background: var(--dark);
  color: rgba(255,255,255,0.65);
  padding: 48px 48px 32px;
}

.footer-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: 48px;
  align-items: start;
}

.footer-logo {
  font-family: var(--font-serif);
  font-size: 2rem;
  font-weight: 600;
  color: var(--white);
  letter-spacing: 0.06em;
  display: block;
  margin-bottom: 10px;
}

.footer-copy {
  font-size: 0.68rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.35);
}

.footer-col h4 {
  font-family: var(--font-sans);
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--white);
  margin-bottom: 14px;
}

.footer-col ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.footer-col ul li a {
  text-decoration: none;
  font-size: 0.78rem;
  color: rgba(255,255,255,0.55);
  transition: color 0.2s;
}

.footer-col ul li a:hover { color: var(--white); }

/* ===== RESPONSIVE ===== */
@media (max-width: 640px) {
  .navbar { padding: 14px 20px; }
  .nav-links { gap: 20px; }
  .footer-inner { grid-template-columns: 1fr; gap: 32px; }
  .footer { padding: 36px 24px 28px; }
}

</style>
<body>

  <!-- NAVBAR -->
  <nav class="navbar">
    <a href="/" class="brand">CHR<span class="brand-icon">⊙</span>NIC</a>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/best-sellers">Best Sellers</a></li>
      <li><a href="/contact">Contact</a></li>
    </ul>
  </nav>

  <!-- MAIN CONTENT -->
  <main class="otp-section">
    <div class="otp-card">
      <h1 class="otp-title">Verify OTP</h1>

      <!-- Alert messages -->
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>

      <div id="alert-box" class="alert" style="display:none;"></div>

      <div class="otp-form-group">
        <input
          type="text"
          id="otp-input"
          class="otp-input"
          placeholder="enter your OTP"
          maxlength="6"
          autocomplete="one-time-code"
        />
        <div class="resend-row">
          <span>DON'T RECIEVE THE OTP?</span>
          <button id="resend-btn" class="resend-btn">RESEND OTP</button>
        </div>
        <button id="confirm-btn" class="confirm-btn">
          <span id="btn-text">CONFIRM</span>
          <span id="btn-spinner" class="spinner" style="display:none;"></span>
        </button>
      </div>
    </div>
  </main>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="footer-logo">CHR<span class="brand-icon">⊙</span>NIC</span>
        <p class="footer-copy">2025 · CHRONIC WATCH</p>
      </div>

      <div class="footer-col">
        <h4>HELP</h4>
        <ul>
          <li><a href="/shipping">Shipping</a></li>
          <li><a href="/contact">Contact Us</a></li>
          <li><a href="/returns">Return &amp; Exchange Policy</a></li>
          <li><a href="/exchange">Exchange request</a></li>
          <li><a href="/warranty">Warranty</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>MENU</h4>
        <ul>
          <li><a href="/about">About me</a></li>
          <li><a href="/privacy">Privacy Policy</a></li>
          <li><a href="/terms">Terms of service</a></li>
        </ul>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
  <script src="/js/verify-otp.js"></script>
</body>
</html>
