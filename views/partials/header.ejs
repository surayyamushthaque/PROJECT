<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || "CHRONIC" %></title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

  <!-- Font Awesome -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

  <!-- ALL CSS HERE (INCLUDING FOOTER) -->
  <style>
    body {
  font-family: Arial, sans-serif;
}

/* Navbar styling */
.navbar {
  transition: all 0.3s ease;
}

.navbar-brand img {
  border-radius: 5px;
}

.nav-link {
  font-weight: 500;
  transition: color 0.3s;
}

.nav-link:hover {
  color: #007bff;
}

/* Logout button */
#logoutBtn {
  border-radius: 20px;
  padding: 5px 15px;
}
  </style>
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold fs-3 d-flex align-items-center" href="/">
      <img src="/images/NEWLOGO.png" alt="Chronic Logo" height="40" class="me-2" />
      CHRONIC
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navMenu">
      <ul class="navbar-nav ms-auto align-items-lg-center">

        <li class="nav-item">
          <a class="nav-link" href="/">Home</a>
        </li>

        <% if (user) { %>
          <li class="nav-item">
            <a class="nav-link fw-bold" href="/user/profile">
              <%= user.name %>
            </a>
          </li>

          <li class="nav-item">
            <button id="logoutBtn" class="btn btn-danger ms-2">Logout</button>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/user/login">
              <i class="fas fa-right-to-bracket me-1"></i> Login
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/user/signup">
              <i class="fas fa-user-plus me-1"></i> Signup
            </a>
          </li>
        <% } %>

        <li class="nav-item">
          <a class="nav-link" href="/cart">
            <i class="fas fa-shopping-cart me-1"></i> Cart
          </a>
        </li>

      </ul>
    </div>
  </div>
</nav>