<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title || "CHRONIC" %></title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>

  <!-- Font Awesome -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet"/>

  <!-- Your CSS -->
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
<style>
  body {
  font-family: Arial, sans-serif;
}

/* Navbar styling */
.navbar {
  transition: all 0.3s ease;
}

.navbar-brand img {
  border-radius: 5px;
}

.nav-link {
  font-weight: 500;
  transition: color 0.3s;
}

.nav-link:hover {
  color: #007bff;
}

/* Logout button */
#logoutBtn {
  border-radius: 20px;
  padding: 5px 15px;
}
</style>
<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold fs-3" href="/user/home">
      CHRONIC
    </a>

    <div class="ms-auto">
      <% if (typeof user !== "undefined" && user) { %>
        <span class="me-3">Welcome, <%= user.name %></span>
        <button class="btn btn-danger" onclick="window.location.href='/user/logout'">
            Logout
            </button>
      <% } else { %>
      
         <!-- <a class="nav-link" href="/">Home</a> -->
        <a href="/user/login" class="me-2">Login</a>
        <a href="/user/signup">Signup</a>
      
      <% } %>
    </div>
  </div>
</nav>